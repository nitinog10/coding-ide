  "version": "1.0.0",
  "description": "Backend service for AI-powered coding IDE platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "init-db": "ts-node scripts/init-db.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
